<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/fondo_naturaleza"
            android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/pantalla_login_raiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp">

        <TextView
                android:id="@+id/txvw_TituloLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-light"
                android:text="Bienvenido de nuevo"
                android:textColor="@color/verde_oscuro"
                android:textSize="32sp"
                app:layout_constraintBottom_toTopOf="@+id/til_CorreoLogin"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_CorreoLogin"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:hint="Correo electronico"
                app:endIconMode="clear_text" 
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/verde_oscuro"
                app:hintTextColor="@color/verde_musgo"
                app:layout_constraintBottom_toTopOf="@+id/til_PassLogin"
                app:layout_constraintTop_toBottomOf="@+id/txvw_TituloLogin">

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_CorreoLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/verde_oscuro" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_PassLogin"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Contrasena"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/verde_oscuro"
                app:hintTextColor="@color/verde_musgo"
                app:layout_constraintBottom_toTopOf="@+id/txvw_OlvidastePass"
                app:layout_constraintTop_toBottomOf="@+id/til_CorreoLogin"
                app:passwordToggleEnabled="true"> 

            <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_PassLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/verde_oscuro" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
                android:id="@+id/txvw_OlvidastePass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="¿Olvidaste tu contrasena?"
                android:textColor="@color/marron_tierra"
                app:layout_constraintBottom_toTopOf="@+id/btn_IniciarSesion"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/til_PassLogin" />

        <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_IniciarSesion"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Entrar al nido"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="@color/verde_oscuro"
                app:cornerRadius="12dp"
                app:layout_constraintBottom_toTopOf="@+id/txvw_IrARegistro"
                app:layout_constraintTop_toBottomOf="@+id/txvw_OlvidastePass" />

        <TextView
                android:id="@+id/txvw_IrARegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-medium"
                android:text="¿No tienes cuenta todavia? Registrate"
                android:textColor="@color/marron_tierra"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_IniciarSesion" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
