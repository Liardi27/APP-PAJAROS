<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_anadir_articulo"
    android:fillViewport="true"
    android:fitsSystemWindows="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clCabecera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E62E4F32"
            android:paddingTop="48dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/btnAtras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt; Atrás"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Nueva Ave"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btnGuardar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guardar"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardObligatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#F2F4F1E1"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/clCabecera">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/btnSubirPortada"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="#DCD8C5"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_camera"
                    app:layout_constraintDimensionRatio="3:4"
                    app:layout_constraintWidth_percent="0.35"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:hint="Nombre Comun *"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btnSubirPortada"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/etNombreCientifico"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="12dp"
                    android:hint="Nombre Cientifico *"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:textStyle="italic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btnSubirPortada"
                    app:layout_constraintTop_toBottomOf="@id/etNombre" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFisico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#F2F4F1E1"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardObligatorio">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETALLES FISICOS"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#2E4F32"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="¿Dismorfia Sexual?"
                        android:textStyle="bold"/>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/swDismorfia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llFotosDismorfia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">
                    <Button android:id="@+id/btnFotoMacho" android:layout_width="match_parent" android:layout_height="60dp" android:text="Subir Imágenes MACHO" android:backgroundTint="#DCD8C5" android:textColor="#333333"/>
                    <Button android:id="@+id/btnFotoHembra" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="8dp" android:text="Subir Imágenes HEMBRA" android:backgroundTint="#DCD8C5" android:textColor="#333333"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardComportamiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#F2F4F1E1"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardFisico">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPORTAMIENTO"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#2E4F32"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="¿Migratorio?"
                        android:textStyle="bold"/>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/swMigratorio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llSeccionMigracion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="4"
                        android:alignmentMode="alignMargins">
                        <CheckBox android:id="@+id/cbEne" android:text="Ene"/><CheckBox android:id="@+id/cbFeb" android:text="Feb"/>
                        <CheckBox android:id="@+id/cbMar" android:text="Mar"/><CheckBox android:id="@+id/cbAbr" android:text="Abr"/>
                        <CheckBox android:id="@+id/cbMay" android:text="May"/><CheckBox android:id="@+id/cbJun" android:text="Jun"/>
                        <CheckBox android:id="@+id/cbJul" android:text="Jul"/><CheckBox android:id="@+id/cbAgo" android:text="Ago"/>
                        <CheckBox android:id="@+id/cbSep" android:text="Sep"/><CheckBox android:id="@+id/cbOct" android:text="Oct"/>
                        <CheckBox android:id="@+id/cbNov" android:text="Nov"/><CheckBox android:id="@+id/cbDic" android:text="Dic"/>
                    </GridLayout>

                    <org.osmdroid.views.MapView
                        android:id="@+id/mapaLibre"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>